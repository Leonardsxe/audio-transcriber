# ── Whisper transcription ─────────────────────────────────────────────
TRANSCRIBER_MODEL_SIZE=large-v3
TRANSCRIBER_LANGUAGE=es
TRANSCRIBER_BEAM_SIZE=5
TRANSCRIBER_VAD_FILTER=true
OUTPUT_DIR=./output

# ── Device & precision ────────────────────────────────────────────────
# CPU configuration (default — works everywhere)
TRANSCRIBER_DEVICE=cpu
TRANSCRIBER_COMPUTE_TYPE=int8

# GPU configuration (uncomment both lines below and comment the two above
# if the host machine has an NVIDIA GPU + nvidia-container-toolkit)
# TRANSCRIBER_DEVICE=cuda
# TRANSCRIBER_COMPUTE_TYPE=float16

# ── Diarization (optional) ────────────────────────────────────────────
# Get a free token at https://hf.co/settings/tokens
# Accept model terms at:
#   https://hf.co/pyannote/speaker-diarization-3.1
#   https://hf.co/pyannote/segmentation-3.0
# HF_TOKEN=hf_your_token_here
